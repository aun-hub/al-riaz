# ─────────────────────────────────────────────────────────────────
# Al-Riaz Associates — Environment Variables Template
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/al-riaz

# ── Database ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=alriaz_db
DB_USER=root
DB_PASS=

# ── Site Identity ─────────────────────────────────────────────────
SITE_NAME=Al-Riaz Associates
SITE_PHONE=+92 300 123 4567
SITE_WHATSAPP=923001234567
SITE_EMAIL=info@alriazassociates.pk

# ── Mail (SMTP) ───────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=Al-Riaz Associates
MAIL_FROM_ADDRESS=info@alriazassociates.pk
MAIL_REPLY_TO=info@alriazassociates.pk

# ── Uploads ───────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=5
